{
  "config_version": 1,
  "objective": {
    "text": "Infer posterior parameters with NUTS",
    "observed_path": "data/observed.json",
    "observed_format": "auto",
    "observed_output_names": [],
    "observed_output_indices": []
  },
  "model": {
    "adapter": "python_callable",
    "path": "model/model.py",
    "callable": "simulate",
    "call_style": "kwargs",
    "command_template": null,
    "working_directory": ".",
    "parameter_names": [
      "theta"
    ],
    "parameter_defaults": {},
    "output_names": [],
    "observed_output_names": [],
    "observed_output_indices": [],
    "timeout_seconds": 300,
    "gradient_strategy": "auto"
  },
  "priors": {
    "theta": {
      "dist": "normal",
      "params": {
        "mean": 0.0,
        "std": 1.0
      }
    }
  },
  "likelihood": {
    "family": "gaussian",
    "params": {
      "sigma_parameter": "obs_sigma",
      "sigma": null,
      "df": 5.0,
      "total_count": null,
      "dispersion_parameter": null,
      "dispersion": null
    },
    "custom_python_path": null,
    "custom_callable": null,
    "custom_command_template": null
  },
  "scaling": {
    "enabled": true,
    "mode": "zscore"
  },
  "sampler": {
    "algorithm": "nuts",
    "backend": "blackjax",
    "random_seed": 7,
    "num_warmup": 1000,
    "num_samples": 1000,
    "num_chains": 4,
    "target_acceptance_rate": 0.85,
    "max_tree_depth": 10,
    "mass_matrix": "diagonal",
    "step_size": null
  },
  "compute": {
    "device_preference": "auto",
    "parallel_mode": "auto",
    "enable_x64": false
  },
  "posterior_predictive": {
    "enabled": true,
    "draws": 100
  },
  "visualization": {
    "enabled": true,
    "plots": [
      "posterior_marginals",
      "trace",
      "posterior_predictive"
    ],
    "dpi": 140
  },
  "output": {
    "results_dir": "results",
    "artifacts_dir": "artifacts"
  }
}
